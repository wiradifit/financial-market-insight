# URL of the Python signal-engine service.
# Used by the browser to fetch signals + market analysis.
NEXT_PUBLIC_SIGNAL_API_URL=http://localhost:8000

# Telegram bot token (from @BotFather) — optional, for signal alerts
# NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl

# Telegram chat ID (from @userinfobot) — optional, for signal alerts
# NEXT_PUBLIC_TELEGRAM_CHAT_ID=-1001234567890
